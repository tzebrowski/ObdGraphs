<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.DefaultTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="android:colorBackground">#121212</item>

        <item name="colorPrimary">@color/philippine_green</item>
        <item name="colorPrimaryVariant">@color/philippine_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/rainbow_indigo</item>
        <item name="colorSecondaryVariant">@color/cardinal</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <item name="android:textColorPrimary">@color/dialog_text_primary</item>
        <item name="android:textColorSecondary">@color/dialog_text_secondary</item>

        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
        <item name="preferenceFragmentCompatStyle">@style/TransparentPreferenceFragment</item>

    </style>

    <style name="TransparentPreferenceFragment" parent="@style/PreferenceFragment">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>